<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Keep-Alive Dashboard - Live</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-color: #f9fafb;
      --card-bg: #ffffff;
      --text-main: #111827;
      --text-muted: #6b7280;
      --border-color: #e5e7eb;
      --primary: #4f46e5;
      --primary-hover: #4338ca;
      --danger: #ef4444;
      --danger-hover: #dc2626;
      --success-bg: #def7ec;
      --success-text: #03543f;
      --error-bg: #fde8e8;
      --error-text: #9b1c1c;
      --ring: rgba(79, 70, 229, 0.2);
    }
    
    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--bg-color);
      color: var(--text-main);
      margin: 0;
      padding: 0;
      -webkit-font-smoothing: antialiased;
    }

    .navbar {
      background-color: var(--card-bg);
      border-bottom: 1px solid var(--border-color);
      padding: 1rem 2rem;
      display: flex;
      align-items: center;
    }

    .navbar h1 {
      margin: 0;
      font-size: 1.25rem;
      font-weight: 600;
      letter-spacing: -0.02em;
    }

    .container {
      max-width: 1024px;
      margin: 2.5rem auto;
      padding: 0 1.5rem;
    }

    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.5rem;
    }

    .page-header h2 {
      margin: 0;
      font-size: 1.5rem;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .live-indicator {
      display: inline-flex;
      background-color: var(--success-bg);
      color: var(--success-text);
      font-size: 0.75rem;
      padding: 0.25rem 0.5rem;
      border-radius: 9999px;
      font-weight: 600;
      text-transform: uppercase;
      align-items: center;
      gap: 5px;
    }
    
    .live-dot {
      width: 6px;
      height: 6px;
      background-color: #10b981;
      border-radius: 50%;
      animation: pulse 1.5s infinite;
    }

    @keyframes pulse {
      0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7); }
      70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
      100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
    }

    button {
      font-family: 'Inter', sans-serif;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.5rem 1rem;
      font-size: 0.875rem;
      font-weight: 500;
      border-radius: 0.375rem;
      transition: all 0.15s ease-in-out;
      border: 1px solid transparent;
    }

    .btn-primary {
      background-color: var(--primary);
      color: white;
    }

    .btn-primary:hover {
      background-color: var(--primary-hover);
    }

    .btn-outline {
      background-color: transparent;
      border-color: var(--border-color);
      color: var(--text-main);
    }

    .btn-outline:hover {
      background-color: #f3f4f6;
    }

    .btn-icon {
      padding: 0.375rem;
      color: var(--text-muted);
      background: transparent;
      border-radius: 0.375rem;
    }

    .btn-icon:hover {
      color: var(--text-main);
      background-color: #f3f4f6;
    }

    .btn-icon.danger:hover {
      color: var(--danger);
      background-color: #fee2e2;
    }

    .card {
      background-color: var(--card-bg);
      border-radius: 0.75rem;
      box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06);
      overflow: hidden;
      border: 1px solid var(--border-color);
    }

    table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }

    th {
      background-color: #f9fafb;
      padding: 0.75rem 1.5rem;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-muted);
      border-bottom: 1px solid var(--border-color);
    }

    td {
      padding: 1rem 1.5rem;
      font-size: 0.875rem;
      color: var(--text-main);
      border-bottom: 1px solid var(--border-color);
      transition: background-color 0.5s ease;
    }

    tbody tr:last-child td {
      border-bottom: none;
    }

    tbody tr:hover {
      background-color: #f9fafb;
    }

    .app-name {
      font-weight: 500;
      color: var(--text-main);
    }

    .app-url {
      color: var(--primary);
      text-decoration: none;
    }

    .app-url:hover {
      text-decoration: underline;
    }

    .status-badge {
      display: inline-flex;
      align-items: center;
      padding: 0.125rem 0.625rem;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 500;
    }

    .status-badge::before {
      content: '';
      display: inline-block;
      width: 0.375rem;
      height: 0.375rem;
      border-radius: 50%;
      margin-right: 0.375rem;
    }

    .status-up {
      background-color: var(--success-bg);
      color: var(--success-text);
    }
    .status-up::before { background-color: #10b981; }

    .status-down {
      background-color: var(--error-bg);
      color: var(--error-text);
    }
    .status-down::before { background-color: #ef4444; }

    .text-muted {
      color: var(--text-muted);
    }

    .actions-flex {
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }

    dialog {
      border: none;
      border-radius: 0.75rem;
      padding: 0;
      width: 100%;
      max-width: 400px;
      box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    }

    dialog::backdrop {
      background-color: rgba(17, 24, 39, 0.5);
      backdrop-filter: blur(2px);
    }

    .dialog-header {
      padding: 1.25rem 1.5rem;
      border-bottom: 1px solid var(--border-color);
    }

    .dialog-header h3 {
      margin: 0;
      font-size: 1.125rem;
      font-weight: 600;
    }

    .dialog-body {
      padding: 1.5rem;
    }

    .dialog-footer {
      padding: 1.25rem 1.5rem;
      background-color: #f9fafb;
      border-top: 1px solid var(--border-color);
      display: flex;
      justify-content: flex-end;
      gap: 0.75rem;
    }

    .form-group {
      margin-bottom: 1.25rem;
    }

    .form-group:last-child {
      margin-bottom: 0;
    }

    .form-group label {
      display: block;
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--text-main);
      margin-bottom: 0.375rem;
    }

    .form-group input {
      width: 100%;
      box-sizing: border-box;
      padding: 0.5rem 0.75rem;
      font-family: inherit;
      font-size: 0.875rem;
      border: 1px solid #d1d5db;
      border-radius: 0.375rem;
      outline: none;
      transition: border-color 0.15s, box-shadow 0.15s;
    }

    .form-group input:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 3px var(--ring);
    }

    .empty-state {
      text-align: center;
      padding: 3rem 1.5rem;
    }

    .empty-state p {
      color: var(--text-muted);
      margin-bottom: 1.5rem;
    }
    
    .row-flash td {
      background-color: #fefce8 !important;
    }
  </style>
</head>
<body>

  <nav class="navbar">
    <h1>Keep-Alive</h1>
  </nav>

  <div class="container">
    <div class="page-header">
      <h2>
        Applications 
        <div class="live-indicator"><div class="live-dot"></div> LIVE WS</div>
      </h2>
      <button class="btn-primary" onclick="document.getElementById('addAppDialog').showModal()">
        <svg style="width:16px;height:16px;margin-right:6px;" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>
        Add App
      </button>
    </div>

    <div class="card">
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>URL</th>
            <th>Status</th>
            <th>Last Check</th>
            <th>Failures</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {{#each apps}}
          <tr id="app-row-{{this.id}}">
            <td>
              <div class="app-name">{{this.name}}</div>
            </td>
            <td>
              <a href="{{this.url}}" target="_blank" class="app-url">{{this.url}}</a>
            </td>
            <td class="app-status">
              {{#if this.failureCount}}
                <span class="status-badge status-down">Down</span>
              {{else}}
                <span class="status-badge status-up">Operational</span>
              {{/if}}
            </td>
            <td class="text-muted app-last-check">
              {{this.lastCheck}}
            </td>
            <td class="text-muted app-failures">
              {{this.failureCount}}
            </td>
            <td>
              <div class="actions-flex">
                <button class="btn-icon" onclick="window.openEditModal({{this.id}}, '{{this.name}}', '{{this.url}}')" title="Edit">
                  <svg style="width:18px;height:18px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                </button>
                <button class="btn-icon danger" onclick="window.deleteApp({{this.id}})" title="Delete">
                  <svg style="width:18px;height:18px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                </button>
              </div>
            </td>
          </tr>
          {{/each}}
          
          {{#unless apps}}
          <tr>
            <td colspan="6">
              <div class="empty-state">
                <svg style="width:48px;height:48px;color:#d1d5db;margin:0 auto 1rem auto;display:block;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                <p>No applications configured yet.</p>
                <button class="btn-primary" onclick="window.document.getElementById('addAppDialog').showModal()">Get Started</button>
              </div>
            </td>
          </tr>
          {{/unless}}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Add Dialog -->
  <dialog id="addAppDialog">
    <form id="addAppForm" method="dialog">
      <div class="dialog-header">
        <h3>Add Application</h3>
      </div>
      <div class="dialog-body">
        <div class="form-group">
          <label>Name</label>
          <input type="text" name="name" required placeholder="e.g. Production API">
        </div>
        <div class="form-group">
          <label>URL</label>
          <input type="url" name="url" required placeholder="https://api.example.com/health">
        </div>
      </div>
      <div class="dialog-footer">
        <button type="button" class="btn-outline" onclick="window.document.getElementById('addAppDialog').close()">Cancel</button>
        <button type="submit" class="btn-primary" id="addAppSubmitBtn">Save Application</button>
      </div>
    </form>
  </dialog>

  <!-- Edit Dialog -->
  <dialog id="editAppDialog">
    <form id="editAppForm" method="dialog">
      <div class="dialog-header">
        <h3>Edit Application</h3>
      </div>
      <div class="dialog-body">
        <input type="hidden" name="id" id="edit-id">
        <div class="form-group">
          <label>Name</label>
          <input type="text" name="name" id="edit-name" required>
        </div>
        <div class="form-group">
          <label>URL</label>
          <input type="url" name="url" id="edit-url" required>
        </div>
      </div>
      <div class="dialog-footer">
        <button type="button" class="btn-outline" onclick="window.document.getElementById('editAppDialog').close()">Cancel</button>
        <button type="submit" class="btn-primary" id="editAppSubmitBtn">Update Configuration</button>
      </div>
    </form>
  </dialog>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    class DashboardController {
      constructor() {
        this.addForm = document.getElementById('addAppForm');
        this.editForm = document.getElementById('editAppForm');
        this.addBtn = document.getElementById('addAppSubmitBtn');
        this.editBtn = document.getElementById('editAppSubmitBtn');
        
        this.initEventListeners();
        this.setupBackdropClick('addAppDialog');
        this.setupBackdropClick('editAppDialog');
        this.initSocket();
      }

      initSocket() {
        if(typeof io === 'undefined') return;
        
        const socket = io();
        socket.on('app_update', (data) => {
          const row = document.getElementById(`app-row-${data.id}`);
          if (!row) return;

          const statusCell = row.querySelector('.app-status');
          const lastCheckCell = row.querySelector('.app-last-check');
          const failuresCell = row.querySelector('.app-failures');

          if (statusCell) {
            if (data.status === 'down') {
              statusCell.innerHTML = '<span class="status-badge status-down">Down</span>';
            } else {
              statusCell.innerHTML = '<span class="status-badge status-up">Operational</span>';
            }
          }
          if (lastCheckCell) lastCheckCell.textContent = data.lastCheck;
          if (failuresCell) failuresCell.textContent = data.failureCount;

          // Flash effect to highlight update visually
          row.classList.add('row-flash');
          setTimeout(() => row.classList.remove('row-flash'), 1000);
        });
      }

      initEventListeners() {
        if (this.addForm) {
          this.addForm.addEventListener('submit', this.handleAddSubmit.bind(this));
        }
        if (this.editForm) {
          this.editForm.addEventListener('submit', this.handleEditSubmit.bind(this));
        }
      }

      async handleAddSubmit(e) {
        e.preventDefault();
        this.toggleButtonState(this.addBtn, true, 'Saving...');
        
        const data = this.getFormData(e.target);
        data.enabled = true;
        
        await this.submitForm('/apps', 'POST', data);
        this.toggleButtonState(this.addBtn, false, 'Save Application');
      }

      async handleEditSubmit(e) {
        e.preventDefault();
        this.toggleButtonState(this.editBtn, true, 'Updating...');
        
        const data = this.getFormData(e.target);
        const appId = data.id;
        delete data.id;
        
        await this.submitForm(`/apps/${appId}`, 'PATCH', data);
        this.toggleButtonState(this.editBtn, false, 'Update Configuration');
      }

      getFormData(form) {
        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
        return data;
      }

      async submitForm(url, method, data) {
        try {
          const res = await fetch(url, {
            method,
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });
          if (res.ok) {
            window.location.reload();
          } else {
            alert(`Error: ${res.statusText}`);
          }
        } catch (err) {
          alert(`Error: ${err.message}`);
        }
      }

      toggleButtonState(btn, disabled, text) {
        if (!btn) return;
        btn.disabled = disabled;
        btn.textContent = text;
      }

      openEditModal(id, name, url) {
        document.getElementById('edit-id').value = id;
        document.getElementById('edit-name').value = name;
        document.getElementById('edit-url').value = url;
        document.getElementById('editAppDialog').showModal();
      }

      async deleteApp(id) {
        if (!confirm('Are you sure you want to delete this application?')) return;
        try {
          const res = await fetch(`/apps/${id}`, { method: 'DELETE' });
          if (res.ok) window.location.reload();
          else alert(`Error: ${res.statusText}`);
        } catch (err) {
          alert(`Error: ${err.message}`);
        }
      }

      setupBackdropClick(dialogId) {
        const dialog = document.getElementById(dialogId);
        if (!dialog) return;
        dialog.addEventListener('click', (e) => {
          const rect = dialog.getBoundingClientRect();
          if (e.clientX < rect.left || e.clientX > rect.right || e.clientY < rect.top || e.clientY > rect.bottom) {
            dialog.close();
          }
        });
      }
    }

    // Initialize controller and expose necessary methods
    const dashboardApp = new DashboardController();
    window.openEditModal = dashboardApp.openEditModal.bind(dashboardApp);
    window.deleteApp = dashboardApp.deleteApp.bind(dashboardApp);
  </script>
</body>
</html>
