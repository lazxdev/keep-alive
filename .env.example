# Server
PORT=3000

# Database — absolute path inside the Docker container
DB_NAME=/app/data/keepalive.db

# Ping timeout in milliseconds
AXIOS_TIMEOUT=5000

# Dashboard credentials — CHANGE THESE before going to production!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# JWT secret — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=keepalive_secret_key
